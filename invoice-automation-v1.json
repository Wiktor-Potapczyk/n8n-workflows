    {
      "parameters": {
        "jsCode": "// Map LLM output fields for Drive rename and Sheets logging\nconst llm = $json.output || $json;\nlet orig;\ntry {\n  orig = $('Code - Derive Month & Filename').item;\n} catch(e) {\n  orig = { json: $json, binary: $binary };\n}\n\n// Sanitize for filename\nlet sellerSafe = (llm.seller_name || 'unknown').replace(/[^a-zA-Z0-9]/g, '_').substring(0, 30);\nlet invoiceSafe = (llm.invoice_number || 'unknown').replace(/[^a-zA-Z0-9]/g, '_').substring(0, 20);\n\nconst datePrefix = orig.json.date_prefix || new Date().toISOString().split('T')[0];\nconst ext = (orig.json.attachment_filename || 'file.pdf').split('.').pop();\nconst finalFilename = datePrefix + '_' + sellerSafe + '_' + invoiceSafe + '.' + ext;\n\nreturn {\n  json: {\n    message_id: orig.json.message_id,\n    email_from: orig.json.email_from,\n    email_subject: orig.json.email_subject,\n    email_date: orig.json.email_date,\n    attachment_filename: orig.json.attachment_filename,\n    month_folder: orig.json.month_folder,\n    invoice_number: llm.invoice_number || '',\n    issue_date: llm.issue_date || '',\n    seller_name: llm.seller_name || '',\n    net_amount: llm.net_amount || '',\n    vat_amount: llm.vat_amount || '',\n    gross_amount: llm.gross_amount || '',\n    currency: llm.currency || '',\n    category: llm.category || '',\n    confidence_score: llm.confidence_score || 0,\n    final_filename: finalFilename\n  },\n  binary: orig.binary\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "map-fields",
      "name": "Code - Map LLM Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2128,
        -224
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Combine LLM-extracted fields with Drive upload output\n// Drive Upload replaces $json with file metadata - restore LLM fields\nconst driveOutput = $json;\nlet llmFields;\ntry {\n  llmFields = $('Code - Map LLM Fields').item.json;\n} catch(e) {\n  llmFields = {};\n}\n\nreturn {\n  json: {\n    message_id: llmFields.message_id || '',\n    invoice_number: llmFields.invoice_number || '',\n    issue_date: llmFields.issue_date || '',\n    seller_name: llmFields.seller_name || '',\n    net_amount: llmFields.net_amount || '',\n    vat_amount: llmFields.vat_amount || '',\n    gross_amount: llmFields.gross_amount || '',\n    currency: llmFields.currency || '',\n    category: llmFields.category || '',\n    confidence_score: llmFields.confidence_score || 0,\n    webViewLink: driveOutput.webViewLink || '',\n    drive_file_id: driveOutput.id || '',\n    drive_file_name: driveOutput.name || ''\n  }\n};"
      },
