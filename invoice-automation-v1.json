        "jsonSchemaExample": "{\n  \"invoice_number\": \"FV/2026/03/001\",\n  \"issue_date\": \"2026-03-27\",\n  \"seller_name\": \"Anthropic PBC\",\n  \"net_amount\": 10.0,\n  \"vat_amount\": 2.3,\n  \"gross_amount\": 12.3,\n  \"currency\": \"USD\",\n  \"category\": \"Software\",\n  \"confidence_score\": 0.95\n}"
      },
