    {
      "parameters": {
        "jsCode": "// Derive month folder name and pre-LLM filename from email metadata\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const emailDate = item.json.email_date;\n  let dateObj;\n  \n  // Parse email date\n  if (emailDate) {\n    dateObj = new Date(emailDate);\n  } else {\n    dateObj = new Date();\n  }\n  \n  const year = dateObj.getFullYear();\n  const month = String(dateObj.getMonth() + 1).padStart(2, '0');\n  const day = String(dateObj.getDate()).padStart(2, '0');\n  \n  const monthFolder = `${year}-${month}`;\n  const datePrefix = `${year}-${month}-${day}`;\n  \n  // Sanitize sender name for filename\n  let sender = item.json.email_from || 'unknown';\n  // Extract name/email from \"Name <email>\" format\n  const nameMatch = sender.match(/^([^<]+)/);\n  if (nameMatch) {\n    sender = nameMatch[1].trim();\n  }\n  sender = sender.replace(/[^a-zA-Z0-9]/g, '_').substring(0, 30);\n  \n  // Short message ID for uniqueness\n  const msgIdShort = (item.json.message_id || 'unknown').substring(0, 8);\n  \n  // Get file extension from original filename\n  const origName = item.json.attachment_filename || 'file';\n  const ext = origName.includes('.') ? origName.split('.').pop() : 'pdf';\n  \n  const preLlmFilename = `${datePrefix}_${sender}_${msgIdShort}.${ext}`;\n  \n  results.push({\n    json: {\n      ...item.json,\n      month_folder: monthFolder,\n      pre_llm_filename: preLlmFilename,\n      date_prefix: datePrefix\n    },\n    binary: item.binary\n  });\n}\n\nreturn results;"
      },
