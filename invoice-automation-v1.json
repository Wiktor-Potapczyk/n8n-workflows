    {
      "parameters": {
        "jsCode": "// Split each email into one item per valid attachment (PDF only)\n// Skip receipts - keep only invoices\nconst results = [];\n// v1: PDF only. Image support (JPG/PNG) deferred — needs vision LLM path.\nconst validMimes = ['application/pdf'];\n\nfor (const item of $input.all()) {\n  const binaryData = item.binary || {};\n  const binaryKeys = Object.keys(binaryData);\n  \n  for (const key of binaryKeys) {\n    const bin = binaryData[key];\n    if (!bin || !bin.mimeType) continue;\n    \n    if (validMimes.includes(bin.mimeType)) {\n      // Skip receipts by filename pattern\n      const fname = (bin.fileName || '').toLowerCase();\n      if (fname.startsWith('receipt') || fname.includes('receipt-')) {\n        continue;\n      }\n      \n      results.push({\n        json: {\n          message_id: item.json.id || item.json.messageId || '',\n          email_from: typeof item.json.from === 'string' ? item.json.from : JSON.stringify(item.json.from || ''),\n          email_subject: item.json.subject || '',\n          email_date: item.json.date || item.json.internalDate || '',\n          attachment_filename: bin.fileName || 'unnamed',\n          mime_type: bin.mimeType,\n          binary_key: key\n        },\n        binary: {\n          attachment: bin\n        }\n      });\n    }\n  }\n}\n\nif (results.length === 0) {\n  results.push({ json: { _empty: true, message: 'No valid attachments found' } });\n}\n\nreturn results;"
      },
